# Local API / MailHog overrides.
# For local UI work, you can temporarily set:
# FRONTEND_URL=http://localhost:5173

FLOWLEDGER_EMAIL_ENABLED=true
FLOWLEDGER_EMAIL_FROM=noreply@flowledger.local
FLOWLEDGER_EMAIL_FROM_NAME=FlowLedger
FRONTEND_URL=https://flowledger.valiantxgroup.com

# AI Platform (UI sidebar appears when GET /api/v1/ai/health succeeds)
FLOWLEDGER_AI_ENABLED=true
FLOWLEDGER_AI_ANALYTICS_ENABLED=true
FLOWLEDGER_AI_VOICE_ENABLED=true
FLOWLEDGER_AI_MULTI_AGENT_ENABLED=true
FLOWLEDGER_AI_WORKFLOW_ENABLED=true
# Optional — without a key, chat/voice return local mock responses
# OPENAI_API_KEY=sk-...
# FLOWLEDGER_AI_PROVIDER=OPENAI
